generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}
model Subscription {

  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  price     Int
  expiresAt DateTime
  createdAt DateTime @default(now())

}
